# Base URL of the tangbuy-plugin backend (injected into the browser bundle via NEXT_PUBLIC_ prefix).
# Copy this file to .env.local and adjust as needed.
NEXT_PUBLIC_API_BASE=https://shop-x2mw.onrender.com

# Browser-direct Tangbuy mall catalog (Render backend cannot reach tangbuy.cc).
# Optional for catalog/itemGet in the browser. Server-side logistics estimate uses
# NEXT_PUBLIC_API_BASE → tangbuy-plugin on Render (TANG_PLUGIN_TANGBUY_MALL_TOKEN).
# For local Next.js without API_BASE, copy the same token here:
# TANG_PLUGIN_TANGBUY_MALL_TOKEN=
NEXT_PUBLIC_TANGBUY_MALL_TOKEN=
NEXT_PUBLIC_TANGBUY_MALL_GATEWAY_BASE_URL=https://tangbuy.cc

# Server-only OpenAI-compatible LLM (products agent copy enrichment).
# Never prefix with NEXT_PUBLIC_ — keys stay on the Next.js server.
LLM_MODEL_BASE_URL=
LLM_MODEL_API_KEY=
LLM_MODEL_MODEL_ID=
