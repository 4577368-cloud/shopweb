# Base URL of the tangbuy-plugin backend (injected into the browser bundle via NEXT_PUBLIC_ prefix).
# Copy this file to .env.local and adjust as needed.
NEXT_PUBLIC_API_BASE=https://shop-x2mw.onrender.com

# Browser-direct Tangbuy mall (catalog, itemGet, logistics line quotes).
# Render / most backends CANNOT reach tangbuy.cc — use the same portal JWT here.
# Copy the value from Render TANG_PLUGIN_TANGBUY_MALL_TOKEN.
# WARNING: exposed in the client bundle — rotate if leaked.
NEXT_PUBLIC_TANGBUY_MALL_TOKEN=
NEXT_PUBLIC_TANGBUY_MALL_GATEWAY_BASE_URL=https://tangbuy.cc

# Server-only Tangbuy admin API (preferred pool ingest — 1688 → 商品库).
# Never prefix with NEXT_PUBLIC_ (except browser ingest below).
TANGBUY_ADMIN_API_BASE=https://admin.tangbuy.cc/prod-api
TANGBUY_ADMIN_TOKEN=
# Browser-direct admin ingest (Vercel/Render cannot reach admin.tangbuy.cc — CORS allows your Vercel domain).
# Set to the same JWT as TANGBUY_ADMIN_TOKEN. Exposed in the client bundle; rotate if leaked.
NEXT_PUBLIC_TANGBUY_ADMIN_BROWSER_TOKEN=
# NEXT_PUBLIC_TANGBUY_ADMIN_API_BASE=https://admin.tangbuy.cc/prod-api
TANGBUY_POOL_DEFAULT_LEVEL=S
# 可选：强制指定入池类目；默认不传 categoryId，由 admin 根据 1688 商品自动映射
# TANGBUY_POOL_CATEGORY_ID=224718765195294
TANGBUY_POOL_OPERATE_USER_ID=1
TANGBUY_POOL_OPERATE_USER_NAME=admin
TANGBUY_POOL_OPERATE_DEPT=100
# JSON array or comma-separated, e.g. ["USA"] or USA
TANGBUY_POOL_DEFAULT_COUNTRIES=

# When Vercel cannot reach admin.tangbuy.cc directly, Next.js may fall back to
# NEXT_PUBLIC_API_BASE + /api/plugin/tangbuy-admin (Render also cannot reach admin — prefer browser token above).
# TANGBUY_ADMIN_SKIP_PLUGIN_PROXY=1
# TANGBUY_ADMIN_PROXY_BASE=

# Server-only OpenAI-compatible LLM (products agent copy enrichment).
# Never prefix with NEXT_PUBLIC_ — keys stay on the Next.js server.
LLM_MODEL_BASE_URL=
LLM_MODEL_API_KEY=
LLM_MODEL_MODEL_ID=
